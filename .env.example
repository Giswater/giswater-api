# Root `.env` — see docs/ENVIRONMENT_VARIABLES.md for full descriptions.
# Copy-paste defaults below; per-tenant keys live in config/tenants/<id>.env.

# --- Routing ---
BASE_DOMAIN=bgeo360.com
TENANTS_DIR=config/tenants

# --- Logging (file + sampled rows to tenant API log table) ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATE_DAYS=14
LOG_DB_ENABLED=true
# 1.0 = log every eligible request to DB (typical for QGIS plugin traffic).
LOG_DB_SAMPLE_RATE=1.0
# Request/response bodies in logs (truncated by LOG_DB_MAX_BODY_BYTES). Set false for metadata-only.
LOG_HTTP_BODY_CAPTURE=true
# Max bytes stored per body; 0 uses internal safe default (2048).
LOG_DB_MAX_BODY_BYTES=2048

# --- Optional DB readiness version gate (tenant GET /gw-api/v1/ready) ---
GISWATER_DB_VERSION_CHECK=false
GISWATER_DB_MIN_VERSION=4.8.0

# --- Rate limiting (max_requests<=0 disables) ---
RATE_LIMIT_DEFAULT_MAX_REQUESTS=30
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60

# --- Admin API (HTTP Basic; Bearer optional via PLATFORM_KEYCLOAK_*) ---
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_RELOAD_ENABLED=true
ADMIN_WRITE_ENABLED=true
ADMIN_ARCHIVE_ON_DELETE=true

# --- Dev only ---
DEV_ALLOW_TENANT_HEADER=false

# --- Platform Keycloak (admin routes; role platform-admin) ---
PLATFORM_KEYCLOAK_ENABLED=false
PLATFORM_KEYCLOAK_URL=
PLATFORM_KEYCLOAK_REALM=
PLATFORM_KEYCLOAK_CLIENT_ID=
PLATFORM_KEYCLOAK_CLIENT_SECRET=

# =============================================================================
# Gunicorn (production Docker image CMD only; ignored when running `uvicorn --reload`).
# Defaults match gunicorn.conf.py — set only when you need overrides.
# =============================================================================
GUNICORN_BIND=0.0.0.0:8000
# Leave unset for auto: min(2 * CPUs + 1, 8). Otherwise set a positive integer.
WEB_CONCURRENCY=
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=2000
GUNICORN_MAX_REQUESTS_JITTER=200
GUNICORN_ACCESSLOG=-
GUNICORN_ERRORLOG=-
GUNICORN_LOG_LEVEL=info
GUNICORN_CAPTURE_OUTPUT=true

# =============================================================================
# Per-tenant env keys (in config/tenants/<id>.env — NOT here): API_BASIC, API_PROFILE,
# API_FLOW, API_MINCUT, API_WATER_BALANCE, API_MAPZONES, API_ROUTING, API_CRM, API_EPA,
# DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD, DB_SCHEMA, DATABASE_URL,
# DB_POOL_MIN_SIZE, DB_POOL_MAX_SIZE, DB_POOL_TIMEOUT, DB_POOL_MAX_WAITING,
# DB_POOL_MAX_IDLE, DB_CONNECT_TIMEOUT,
# KEYCLOAK_ENABLED, KEYCLOAK_URL, KEYCLOAK_REALM, KEYCLOAK_CLIENT_ID,
# KEYCLOAK_CLIENT_SECRET, KEYCLOAK_ADMIN_CLIENT_ID, KEYCLOAK_ADMIN_CLIENT_SECRET,
# KEYCLOAK_CALLBACK_URI
# Full template: config/tenants/example.env
# =============================================================================
