# Routing
BASE_DOMAIN=bgeo360.com
TENANTS_DIR=config/tenants

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATE_DAYS=14
LOG_DB_ENABLED=true
LOG_DB_SAMPLE_RATE=1.0
LOG_DB_MAX_BODY_BYTES=0

# Endpoint rate limiting (set max_requests<=0 to disable)
RATE_LIMIT_DEFAULT_MAX_REQUESTS=30
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60

# Admin (HTTP Basic always available; Bearer optional via PLATFORM_KEYCLOAK_*)
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_RELOAD_ENABLED=true
ADMIN_WRITE_ENABLED=true
ADMIN_ARCHIVE_ON_DELETE=true

# Dev-only: honor X-Tenant-ID on non-`BASE_DOMAIN` hosts (localhost, IPs)
DEV_ALLOW_TENANT_HEADER=false

# Platform Keycloak (separate from per-tenant Keycloak; required role: platform-admin)
PLATFORM_KEYCLOAK_ENABLED=false
PLATFORM_KEYCLOAK_URL=
PLATFORM_KEYCLOAK_REALM=
PLATFORM_KEYCLOAK_CLIENT_ID=
PLATFORM_KEYCLOAK_CLIENT_SECRET=
