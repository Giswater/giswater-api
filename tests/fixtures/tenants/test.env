API_BASIC=true
API_PROFILE=true
API_FLOW=true
API_MINCUT=true
API_WATER_BALANCE=true
API_MAPZONES=true
API_ROUTING=true
API_CRM=true
API_EPA=true

DB_HOST=host.containers.internal
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
DB_POOL_TIMEOUT=10
DB_POOL_MAX_WAITING=0
DB_POOL_MAX_IDLE=60
DB_CONNECT_TIMEOUT=5

KEYCLOAK_ENABLED=false
