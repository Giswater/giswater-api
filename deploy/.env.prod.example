# Production .env — single-tenant mode (SINGLE_TENANT_ID=main).
# Full reference: docs/ENVIRONMENT_VARIABLES.md
# Generated by deploy/install.sh into INSTALL_DIR/.env

# --- Docker Compose image (used for ${...} interpolation in docker-compose.yml) ---
GISWATER_API_IMAGE=bgeoopengis/giswater-api
GISWATER_API_TAG=latest

# --- Routing (single-tenant: IP or single host, no DNS required) ---
SINGLE_TENANT_ID=main
TENANTS_DIR=config/tenants
API_ROOT=/giswater

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATE_DAYS=14
LOG_DB_ENABLED=true
LOG_DB_SAMPLE_RATE=1.0
LOG_HTTP_BODY_CAPTURE=true
LOG_DB_MAX_BODY_BYTES=2048
LOG_DB_RESPONSE_MAX_BYTES=8192

# --- Rate limiting ---
RATE_LIMIT_DEFAULT_MAX_REQUESTS=60
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60

# --- Admin API (HTTP Basic) ---
ADMIN_USER=admin
ADMIN_PASSWORD=
ADMIN_RELOAD_ENABLED=false
ADMIN_WRITE_ENABLED=false
ADMIN_ARCHIVE_ON_DELETE=true

DEV_ALLOW_TENANT_HEADER=false

# --- Platform Keycloak (admin routes; optional) ---
PLATFORM_KEYCLOAK_ENABLED=false
PLATFORM_KEYCLOAK_URL=
PLATFORM_KEYCLOAK_REALM=
PLATFORM_KEYCLOAK_CLIENT_ID=
PLATFORM_KEYCLOAK_CLIENT_SECRET=

# --- DB readiness gate ---
GISWATER_DB_VERSION_CHECK=true
GISWATER_DB_MIN_VERSION=4.8.0

# --- Gunicorn (production Docker CMD; see gunicorn.conf.py) ---
GUNICORN_BIND=0.0.0.0:8000
WEB_CONCURRENCY=
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=2000
GUNICORN_MAX_REQUESTS_JITTER=200
GUNICORN_ACCESSLOG=-
GUNICORN_ERRORLOG=-
GUNICORN_LOG_LEVEL=info
GUNICORN_CAPTURE_OUTPUT=true

# Per-tenant: config/tenants/main.env (see deploy/main.env.example)
