# Example: host nginx (outside Docker) proxies to giswater-api on loopback.
# Copy and adjust server_name, SSL paths, and upstream port.
#
# Requirements:
#   - proxy_set_header Host $host;  (the app resolves tenant from Host)
#   - App listens at 127.0.0.1:8000 (see docker-compose.yml ports)

# Apex domain: platform admin API only
server {
    listen 443 ssl;
    server_name bgeo360.com;

    location /admin/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        return 404;
    }
}

# Tenant subdomains: Giswater API under /gw-api/v1 (other apps can use more location blocks)
server {
    listen 443 ssl;
    server_name ~^(?<tid>[a-z0-9-]+)\.bgeo360\.com$;

    location /gw-api/v1/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Example: another app on the same tenant host
    # location /other-app/ {
    #     proxy_pass http://127.0.0.1:9000;
    #     proxy_set_header Host $host;
    # }
}
