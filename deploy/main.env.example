# Per-tenant configuration for single-tenant production (main.env).
# Filename stem must match SINGLE_TENANT_ID in .env (default: main).

# API toggles
API_BASIC=true
API_PROFILE=true
API_FLOW=true
API_MINCUT=true
API_WATER_BALANCE=true
API_MAPZONES=true
API_ROUTING=true
API_CRM=true
API_EPA=true

# Database
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_SCHEMA=ws_40

DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30
DB_POOL_MAX_WAITING=0
DB_POOL_MAX_IDLE=300
DB_CONNECT_TIMEOUT=5

# Keycloak (per tenant). Prefer AUTH_MODE=keycloak|basic|none
AUTH_MODE=none
# DEPRECATED #22: use AUTH_MODE=keycloak instead
KEYCLOAK_ENABLED=false
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_CALLBACK_URI=
