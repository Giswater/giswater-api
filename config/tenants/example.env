# Per-tenant configuration. Filename stem = tenant id (must match the
# subdomain). Example: this file at config/tenants/acme.env serves
# https://acme.bgeo360.com/gw-api/v1/...
#
# Tenant id rules: ^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$
# Reserved: www, api, admin, static, traefik, localhost.

# API toggles
API_BASIC=true
API_PROFILE=true
API_FLOW=true
API_MINCUT=true
API_WATER_BALANCE=true
API_MAPZONES=true
API_ROUTING=true
API_CRM=true
API_EPA=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Pool sizing (per tenant). Total connections = N_tenants × DB_POOL_MAX_SIZE.
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30
DB_POOL_MAX_WAITING=0
DB_POOL_MAX_IDLE=300
DB_CONNECT_TIMEOUT=5

# Keycloak (per tenant). Disable to allow anonymous access.
KEYCLOAK_ENABLED=false
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_CALLBACK_URI=
