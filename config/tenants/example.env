# Per-tenant configuration. Filename stem = tenant id.
#
# - DNS multi-tenant mode: the stem must match the subdomain. Example:
#   config/tenants/acme.env serves https://acme.bgeo360.com${API_ROOT}/v1/...
#   (default API_ROOT is /giswater).
# - Single-tenant mode (SINGLE_TENANT_ID set in .env): the stem only needs to
#   match SINGLE_TENANT_ID (e.g. `main.env` for SINGLE_TENANT_ID=main). No DNS
#   subdomain required; the app serves this tenant on any Host.
#
# Tenant id rules: ^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$
# Reserved: www, api, admin, static, traefik, localhost.

# API toggles
API_BASIC=true
API_PROFILE=true
API_FLOW=true
API_MINCUT=true
API_WATER_BALANCE=true
API_MAPZONES=true
API_ROUTING=true
API_CRM=true
API_EPA=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Pool sizing (per tenant). Total connections = N_tenants × DB_POOL_MAX_SIZE.
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30
DB_POOL_MAX_WAITING=0
DB_POOL_MAX_IDLE=300
DB_CONNECT_TIMEOUT=5

# Auth mode (per tenant). `none`, `basic` or `keycloak`
AUTH_MODE=none
# When `AUTH_MODE=basic`, optional first user if gwapi.users is empty.
# AUTH_BASIC_BOOTSTRAP_USER=user
# AUTH_BASIC_BOOTSTRAP_PASSWORD=changeme

# Keycloak configuration (per tenant)
# KEYCLOAK_ENABLED=false  # DEPRECATED #22: use AUTH_MODE=keycloak instead of KEYCLOAK_ENABLED=true
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_CALLBACK_URI=
